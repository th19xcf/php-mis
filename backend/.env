#--------------------------------------------------------------------
# Production environment template for MIS backend
# Copy this file to .env on the production server and replace placeholder values.
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'http://mis.localhost/'
app.forceGlobalSecureRequests = false
app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
database.btdc.hostname = 114.113.154.36
database.btdc.database = data
database.btdc.username = data
database.btdc.password = MYSQL.data2023
database.btdc.DBDriver = MySQLi
database.btdc.DBPrefix =
database.btdc.port = 45608
database.btdc.charset = utf8mb4
database.btdc.DBCollat = utf8mb4_general_ci

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------
logger.threshold = 4

#--------------------------------------------------------------------
# SECURITY
#--------------------------------------------------------------------
JWT_SECRET = replace-with-a-long-random-production-secret

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------
session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
session.savePath = D:/code/php/mis/backend/writable/session

#--------------------------------------------------------------------
# AUTH DEBUG (local only)
#--------------------------------------------------------------------
AUTH_DEBUG_ENABLED = true
AUTH_DEBUG_USER = debug
AUTH_DEBUG_PASS = debug123
AUTH_DEBUG_REGION = 北京总公司
AUTH_DEBUG_BIND_WORK_ID =
AUTH_DEBUG_ROLES = R_SUPER,R_ADMIN
AUTH_DEBUG_BUTTONS = dashboard:view,system:user:add,system:user:edit
