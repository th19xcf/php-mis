#--------------------------------------------------------------------
# Production environment template for MIS backend
# Copy this file to .env on the production server and replace placeholder values.
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'https://your-domain.example.com/'
app.forceGlobalSecureRequests = true
app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
database.default.hostname = your-db-host
database.default.database = your-db-name
database.default.username = your-db-user
database.default.password = your-db-password
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_general_ci

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------
logger.threshold = 4

#--------------------------------------------------------------------
# SECURITY
#--------------------------------------------------------------------
JWT_SECRET = replace-with-a-long-random-production-secret

#--------------------------------------------------------------------
# TOKEN BLACKLIST
#--------------------------------------------------------------------
# 存储驱动：'file'（默认，单实例） | 'redis'（推荐，多实例）
# 切换为 redis 后必须配置下方 REDIS_BL_* 变量
# TOKEN_BLACKLIST_DRIVER = redis

# Redis 连接配置（仅当 TOKEN_BLACKLIST_DRIVER=redis 时生效）
# REDIS_BL_HOST = 127.0.0.1
# REDIS_BL_PORT = 6379
# REDIS_BL_PASSWORD =
# REDIS_BL_DB = 0
# REDIS_BL_PREFIX = mis:bl:

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------
session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
session.savePath = /path/to/project/backend/writable/session
